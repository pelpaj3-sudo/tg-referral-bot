# Токен бота від @BotFather
BOT_TOKEN=

# Telegram ID адміністраторів через кому (без @). Дізнатись свій ID можна у @userinfobot
ADMIN_IDS=

# Публічний канал для верифікації, напр. @my_channel
# Якщо канал приватний — залиште CHANNEL_USERNAME порожнім і заповніть CHANNEL_ID + CHANNEL_INVITE_LINK
CHANNEL_USERNAME=

# Використовується лише для приватних каналів (chat id виду -100XXXXXXXXXX)
CHANNEL_ID=

# Посилання-запрошення для приватного каналу (якщо CHANNEL_USERNAME порожній)
CHANNEL_INVITE_LINK=

# Скільки гривень нараховувати за одного верифікованого реферала
REFERRAL_BONUS=7

# Мінімальна сума для виведення, грн
MIN_WITHDRAWAL=70

# Контакт підтримки, який показується користувачам
SUPPORT_CONTACT=@support
